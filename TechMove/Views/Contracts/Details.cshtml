@model ContractModel

@{
    ViewData["Title"] = "Contract Details";
}

<h2>Contract Details</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Model.Client?.Name</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@Model.ServiceLevel</dd>

            <dt class="col-sm-3">Signed Agreement</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.SignedAgreementFileName))
                {
                    <a asp-action="DownloadAgreement"
                       asp-route-id="@Model.ContractId"
                       class="btn btn-primary btn-sm">
                        Download PDF
                    </a>
                }
                else
                {
                    <span>No agreement uploaded.</span>
                }
            </dd>
        </dl>
    </div>
</div>

<h4 class="mt-4">Service Requests</h4>

@if (Model.ServiceRequests != null && Model.ServiceRequests.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Request ID</th>
                <th>Status</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model.ServiceRequests)
            {
                <tr>
                    <td>@request.ServiceRequestId</td>
                    <td>@request.Status</td>
                    <td>@request.Description</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No service requests linked to this contract.</p>
}

<a asp-action="Index" class="btn btn-secondary">Back to List</a>