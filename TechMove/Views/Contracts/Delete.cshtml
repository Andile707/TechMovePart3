@model ContractModel

@{
    ViewData["Title"] = "Delete Contract";
}

<h2>Delete Contract</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this contract?
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Model.Client?.Name</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@Model.ServiceLevel</dd>

            <dt class="col-sm-3">Agreement</dt>
            <dd class="col-sm-9">@Model.SignedAgreementFileName</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.ContractId" method="post">
            @Html.AntiForgeryToken()

            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Details" asp-route-id="@Model.ContractId" class="btn btn-info">Cancel</a>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </form>
    </div>
</div>