@model IEnumerable<ClientModel>

<h1>Clients</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create Client</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Contact Details</th>
            <th>Region</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.Name</td>
                <td>@client.ContactDetails</td>
                <td>@client.Region</td>
                <td>
                    <a asp-action="Details" asp-route-id="@client.ClientId">Details</a> |
                    <a asp-action="Edit" asp-route-id="@client.ClientId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@client.ClientId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>