@model IEnumerable<ContractModel>

@{
    ViewData["Title"] = "Contracts";
}

<h2>Contracts</h2>

<form asp-action="Index" method="get" class="row mb-3">
    <div class="col-md-3">
        <label>Start Date</label>
        <input type="date" name="startDate" class="form-control"
               value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
    </div>

    <div class="col-md-3">
        <label>End Date</label>
        <input type="date" name="endDate" class="form-control"
               value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
    </div>

    <div class="col-md-3">
        <label>Status</label>
        <select name="status" class="form-control" asp-items="Html.GetEnumSelectList<ContractStatus>()">
            <option value="">All</option>
        </select>
    </div>

    <div class="col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">Filter</button>
        <a asp-action="Index" class="btn btn-secondary">Reset</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Contract</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Client</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Service Level</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var contract in Model)
        {
            <tr>
                <td>@contract.Client?.Name</td>
                <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                <td>@contract.Status</td>
                <td>@contract.ServiceLevel</td>
                <td>
                    <a asp-action="Details" asp-route-id="@contract.ContractId"
                       class="btn btn-info btn-sm">
                        Details
                    </a>

                    <a asp-action="Edit" asp-route-id="@contract.ContractId"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@contract.ContractId"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>