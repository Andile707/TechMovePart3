@model ClientModel

<h1>Client Details</h1>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Telephone Number</dt>
    <dd class="col-sm-9">@Model.TelephoneNumber</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Region</dt>
    <dd class="col-sm-9">@Model.Region</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.ClientId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
