@model ServiceRequestModel

@{
    ViewData["Title"] = "Edit Service Request";
}

<h2>Edit Service Request</h2>

<form asp-action="Edit" asp-route-id="@Model.ServiceRequestId" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="ServiceRequestId" />
    <input type="hidden" asp-for="CostZAR" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="ContractId" class="form-label">Contract</label>
        <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId">
            <option value="">-- Select Contract --</option>
        </select>
        <span asp-validation-for="ContractId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CostUSD" class="form-label">Cost USD</label>
        <input asp-for="CostUSD" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="CostUSD" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <input asp-for="Status" class="form-control" />
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning">Save Changes</button>
    <a asp-action="Details" asp-route-id="@Model.ServiceRequestId" class="btn btn-info">Details</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
