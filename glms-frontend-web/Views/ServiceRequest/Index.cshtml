@model IEnumerable<ServiceRequestModel>

@{
    ViewData["Title"] = "Service Requests";
}

<h2>Service Requests</h2>

<p>
    <a asp-action="Create" class="btn btn-success">
        Create New Service Request
    </a>
</p>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Request ID</th>
            <th>Contract</th>
            <th>Description</th>
            <th>Cost USD</th>
            <th>Cost ZAR</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ServiceRequestId</td>

                    <td>
                        Contract #@item.ContractId
                        (@item.Contract?.Status)
                    </td>

                    <td>@item.Description</td>

                    <td>
                        $ @item.CostUSD.ToString("N2")
                    </td>

                    <td>
                        R @item.CostZAR.ToString("N2")
                    </td>

                    <td>@item.Status</td>

                    <td>
                        <a asp-action="Details"
                           asp-route-id="@item.ServiceRequestId"
                           class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.ServiceRequestId"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.ServiceRequestId"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">
                    No service requests found.
                </td>
            </tr>
        }
    </tbody>
</table>
