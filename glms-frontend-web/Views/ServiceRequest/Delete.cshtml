@model ServiceRequestModel

@{
    ViewData["Title"] = "Delete Service Request";
}

<h2>Delete Service Request</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this service request?
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Service Request ID</dt>
            <dd class="col-sm-9">@Model.ServiceRequestId</dd>

            <dt class="col-sm-3">Contract</dt>
            <dd class="col-sm-9">@Model.Contract?.ServiceLevel</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Cost USD</dt>
            <dd class="col-sm-9">@Model.CostUSD.ToString("C")</dd>

            <dt class="col-sm-3">Cost ZAR</dt>
            <dd class="col-sm-9">R @Model.CostZAR.ToString("N2")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.ServiceRequestId" method="post">
            @Html.AntiForgeryToken()

            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Details" asp-route-id="@Model.ServiceRequestId" class="btn btn-info">Cancel</a>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </form>
    </div>
</div>
